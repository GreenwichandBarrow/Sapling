# Environment secrets
.env
scripts/.env.launchd

# Scheduled skill logs
logs/

# Claude Code runtime
.claude/settings.local.json

# Skill outputs and secrets
.claude/skills/*/output/
.claude/skills/*/.env

# OS files
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo
*~

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node (if using any JS tools)
node_modules/

# Obsidian (if vault root doubles as repo)
.obsidian/workspace.json
.obsidian/workspaces.json

# Personal brain content (user-specific, not boilerplate)
brain/notes/daily/
brain/notes/weekly/
brain/notes/monthly/
brain/notes/quarterly/
brain/notes/yearly/
brain/plans/
brain/context/about-me.md
brain/context/business.md
brain/context/voice-and-style.md
brain/context/preferences.md

# Plugin symlinks (user-specific)
.claude/loop-agents
.claude/loop-completions.json
.mcp.json
.granola-key
.motion-key

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Backup files from credential rotations — contain stale/revoked keys, never commit
scripts/.env*.bak*

# Task tracker xlsx (source of truth is Google Drive; outputs/ is a working copy)
outputs/TO DO *.xlsx
outputs/TO DO *.bak.*.xlsx
